#!/bin/bash
set -euo pipefail

HOSTED_INSTALLER_URL="https://raw.githubusercontent.com/agoodkind/go-makefile/main/install.sh"
readonly HOSTED_INSTALLER_URL

printf '%s\0' "$@" >"$CAPTURE_DIR/curl-args"

if [[ "${!#}" != "$HOSTED_INSTALLER_URL" ]]; then
    exit 86
fi

printf '%s\n' '# hosted installer sentinel'
