# agent-gate configuration
#
# Copy this file to your XDG config directory:
#
#   mkdir -p "${XDG_CONFIG_HOME:-$HOME/.config}/agent-gate"
#   cp config.toml.example "${XDG_CONFIG_HOME:-$HOME/.config}/agent-gate/config.toml"
#
# Then edit to taste. agent-gate will not start if no config file is found.

[log]
level = "debug"   # debug | info | warn | error

# ── Path overrides (optional) ────────────────────────────────────────────────
#
# By default agent-gate writes normalized audit events under:
#
#   $XDG_STATE_HOME/agent-gate/events/YYYY/MM/DD/events.jsonl
#   $XDG_STATE_HOME/agent-gate/payloads/sha256/ab/cd/<hash>.json
#                  ($XDG_STATE_HOME defaults to ~/.local/state)
#
# conversations_dir is legacy and only kept for compatibility with older logs.

[paths]
conversations_dir = ""   # example: "/var/log/agent-gate/conversations"

[audit]
enabled = true
level = "debug"

[audit.outputs.jsonl]
enabled = true
events_dir = ""
payloads_dir = ""
write_raw_payloads = true

[audit.outputs.sqlite]
enabled = false
path = ""

[audit.query]
prefer = "sqlite" # sqlite | jsonl

# ── Rules ────────────────────────────────────────────────────────────────────
#
# Each rule is evaluated in order. The first matching rule wins.
#
# Fields:
#   name              - unique identifier shown in audit log and error messages
#   description       - human-readable explanation
#   events            - hook event names this rule applies to (empty = all)
#   field_paths       - dot-path(s) into the JSON payload to inspect;
#                       first non-empty value found across all paths is tested
#   pattern           - PCRE2 regex matched against the extracted field value
#   action            - what to do on match: "block" is the only supported action
#   violation_message - message sent back to the AI and written to the audit log
#
# Conditional rules can use:
#   kind = "regex"    - default; uses field_paths plus pattern/not_pattern
#   kind = "command"  - matches shell command segments by argv0/subcommands
#   kind = "project"  - checks files relative to a discovered project root

[[rules]]
name        = "no-shell-redirection"
description = "Block shell output/error redirection patterns LLMs commonly emit to suppress errors"
events      = ["PreToolUse", "beforeShellExecution", "preToolUse", "BeforeTool"]
field_paths = ["tool_input.command", "command"]
pattern     = '(\d+>&\d+|>&\d+|&>|\|&|>/dev/null|2>/dev/null|>>/dev/null|2>>/dev/null|&>/dev/null)'
action      = "block"
violation_message = "Shell redirection is not permitted (e.g. 2>&1, >/dev/null, &>). Express output handling explicitly without redirects."

[[rules]]
name        = "go-build-test-through-make"
description = "Require make for Go build/test in Go modules that provide a Makefile"
claude_events = ["PreToolUse"]
cursor_events = ["preToolUse", "beforeShellExecution"]
codex_events  = ["PreToolUse"]
gemini_events = ["BeforeTool"]
action      = "block"
violation_message = "This Go project has a Makefile. Use the appropriate make target instead of calling go build or go test directly."

[[rules.conditions]]
kind        = "command"
argv0       = "go"
subcommands = ["build", "test"]
strip_env   = true
strip_args  = ["env", "time", "command"]
cwd_flags   = ["-C"]
pattern     = '^(?:build(?:\s|$)|test(?:\s+.*)?\s(?:\./\.\.\.|all)(?:\s|$))'

[[rules.conditions]]
kind         = "project"
root_markers = ["go.mod"]
require_any  = ["Makefile", "makefile", "GNUmakefile"]

# Emdash enforcement: block on new output, audit on existing content.

[[rules]]
name        = "no-emdashes"
description = "Block Unicode dash variants in all LLM-generated output"
claude_events = [
  "PreToolUse", "PostToolUse", "PostToolUseFailure",
  "Stop", "StopFailure",
  "SubagentStart", "SubagentStop",
  "SessionStart", "SessionEnd",
  "UserPromptSubmit",
  "PermissionRequest", "PermissionDenied",
  "Notification",
  "ConfigChange", "CwdChanged", "InstructionsLoaded",
  "PreCompact", "PostCompact",
  "WorktreeCreate", "WorktreeRemove",
  "FileChanged",
  "TaskCreated", "TaskCompleted",
  "Elicitation", "ElicitationResult",
  "TeammateIdle",
]
cursor_events = [
  "preToolUse", "postToolUse",
  "beforeShellExecution",
  "beforeMCPExecution", "beforeSubmitPrompt", "beforeReadFile",
  "afterFileEdit", "afterAgentResponse",
  "stop",
]
codex_events = [
  "PreToolUse", "PostToolUse",
  "PermissionRequest", "UserPromptSubmit", "Stop",
]
gemini_events = [
  "BeforeTool", "AfterTool",
  "BeforeAgent", "AfterAgent",
  "BeforeModel", "AfterModel",
  "SessionStart", "SessionEnd",
  "Notification", "PreCompress",
]
# All LLM-generated text fields except tool_input.prompt (handled by the next rule).
# old_string excluded -- existing content doesn't trigger a block.
field_paths = ["tool_input.content", "tool_input.new_string", "tool_input.command", "tool_input.description", "command", "assistant_message", "last_assistant_message", "text"]
# U+2010..U+2015, U+2212, U+2E3A, U+2E3B, U+FE31, U+FE32, U+FE58, U+FE63, U+FF0D
# All 30 Unicode Dash characters (Dash=Yes per PropList.txt) except U+002D
# (ASCII hyphen-minus). Source: unicode.org/Public/UCD/latest/ucd/PropList.txt
pattern     = '[\x{058A}\x{05BE}\x{1400}\x{1806}\x{2010}-\x{2015}\x{2053}\x{207B}\x{208B}\x{2212}\x{2E17}\x{2E1A}\x{2E3A}\x{2E3B}\x{2E40}\x{2E5D}\x{301C}\x{3030}\x{30A0}\x{FE31}\x{FE32}\x{FE58}\x{FE63}\x{FF0D}\x{10D6E}\x{10EAD}]'
action      = "block"
violation_message = "This output contains a typographic dash character. Rewrite without Unicode dash variants."

[[rules]]
name        = "no-emdashes-tool-input-prompt-unless-subagent-task"
description = "Block typographic dashes in tool_input.prompt except for Task (sub-agent) tool invocations"
claude_events = ["PreToolUse"]
cursor_events = ["preToolUse"]
codex_events = ["PreToolUse"]
gemini_events = ["BeforeTool"]
action      = "block"
violation_message = "This output contains a typographic dash character. Rewrite without Unicode dash variants."

[[rules.conditions]]
field_paths = ["tool_input.prompt"]
pattern     = '[\x{058A}\x{05BE}\x{1400}\x{1806}\x{2010}-\x{2015}\x{2053}\x{207B}\x{208B}\x{2212}\x{2E17}\x{2E1A}\x{2E3A}\x{2E3B}\x{2E40}\x{2E5D}\x{301C}\x{3030}\x{30A0}\x{FE31}\x{FE32}\x{FE58}\x{FE63}\x{FF0D}\x{10D6E}\x{10EAD}]'

[[rules.conditions]]
field_paths = ["tool_name"]
not_pattern = "(?i)^task$"

[[rules]]
name        = "no-double-hyphen-prose"
description = "Block ASCII double-hyphen used as a lazy prose em dash, while allowing command flags and option separators"
claude_events = [
  "PreToolUse", "PostToolUse", "PostToolUseFailure",
  "Stop", "StopFailure",
  "SubagentStart", "SubagentStop",
  "SessionStart", "SessionEnd",
  "UserPromptSubmit",
  "PermissionRequest", "PermissionDenied",
  "Notification",
  "ConfigChange", "CwdChanged", "InstructionsLoaded",
  "PreCompact", "PostCompact",
  "WorktreeCreate", "WorktreeRemove",
  "FileChanged",
  "TaskCreated", "TaskCompleted",
  "Elicitation", "ElicitationResult",
  "TeammateIdle",
]
cursor_events = [
  "preToolUse", "postToolUse",
  "beforeMCPExecution", "beforeSubmitPrompt", "beforeReadFile",
  "afterFileEdit", "afterAgentResponse",
  "stop",
]
codex_events = [
  "PreToolUse", "PostToolUse",
  "PermissionRequest", "UserPromptSubmit", "Stop",
]
gemini_events = [
  "BeforeTool", "AfterTool",
  "BeforeAgent", "AfterAgent",
  "BeforeModel", "AfterModel",
  "SessionStart", "SessionEnd",
  "Notification", "PreCompress",
]
field_paths = ["tool_input.content", "tool_input.new_string", "tool_input.description", "edits[*].new_string", "assistant_message", "last_assistant_message", "text"]
pattern     = '(?m)(?:(?:`[^`\n]+`|\b(?!(?:bash|sh|zsh|fish|exec|command|env|xargs|sudo|doas|go|git|make|npm|pnpm|yarn|node|python|python3|ruby|perl|cargo|docker|kubectl|helm|terraform|ansible|rg|grep|sed|awk|jq|curl|ssh|scp|rsync)\b)[A-Za-z][A-Za-z0-9_./-]*)\s+--\s+[A-Za-z][A-Za-z0-9_./-]*|\b(?!(?:bash|sh|zsh|fish|exec|command|env|xargs|sudo|doas|go|git|make|npm|pnpm|yarn|node|python|python3|ruby|perl|cargo|docker|kubectl|helm|terraform|ansible|rg|grep|sed|awk|jq|curl|ssh|scp|rsync)\b)[A-Za-z][A-Za-z0-9_./-]*--[A-Za-z][A-Za-z0-9_./-]*)'
action      = "block"
violation_message = "This output uses ASCII double-hyphen as a lazy prose dash. Rewrite the sentence without `--`; use separate sentences or punctuation that is not pretending to be an em dash. Command flags like `--help` and option separators like `exec -- input` are allowed in command contexts."

[[rules]]
name        = "emdash-audit-existing"
description = "Audit log when the LLM edits a region containing existing emdashes (does not block)"
claude_events = ["PreToolUse"]
cursor_events = ["preToolUse"]
codex_events = ["PreToolUse"]
gemini_events = ["BeforeTool"]
field_paths = ["tool_input.old_string"]
# All 30 Unicode Dash characters (Dash=Yes per PropList.txt) except U+002D
# (ASCII hyphen-minus). Source: unicode.org/Public/UCD/latest/ucd/PropList.txt
pattern     = '[\x{058A}\x{05BE}\x{1400}\x{1806}\x{2010}-\x{2015}\x{2053}\x{207B}\x{208B}\x{2212}\x{2E17}\x{2E1A}\x{2E3A}\x{2E3B}\x{2E40}\x{2E5D}\x{301C}\x{3030}\x{30A0}\x{FE31}\x{FE32}\x{FE58}\x{FE63}\x{FF0D}\x{10D6E}\x{10EAD}]'
action      = "block"
audit_only  = true
violation_message = "Existing content contains typographic dashes. The LLM should clean these up in its replacement."
