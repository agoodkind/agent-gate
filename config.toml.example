# agent-gate configuration
#
# Copy this file to your XDG config directory:
#
#   mkdir -p "${XDG_CONFIG_HOME:-$HOME/.config}/agent-gate"
#   cp config.toml.example "${XDG_CONFIG_HOME:-$HOME/.config}/agent-gate/config.toml"
#
# Then edit to taste. agent-gate will not start if no config file is found.

[log]
level = "debug"   # debug | info | warn | error

# ── Path overrides (optional) ────────────────────────────────────────────────
#
# By default agent-gate writes normalized audit events under:
#
#   $XDG_STATE_HOME/agent-gate/events/YYYY/MM/DD/events.jsonl
#   $XDG_STATE_HOME/agent-gate/payloads/sha256/ab/cd/<hash>.json
#                  ($XDG_STATE_HOME defaults to ~/.local/state)
#
# conversations_dir is legacy and only kept for compatibility with older logs.

[paths]
conversations_dir = ""   # example: "/var/log/agent-gate/conversations"

[audit]
enabled = true
level = "debug"

[audit.outputs.jsonl]
enabled = true
events_dir = ""
payloads_dir = ""
write_raw_payloads = true

[audit.outputs.sqlite]
enabled = false
path = ""

[audit.query]
prefer = "sqlite" # sqlite | jsonl

# ── Rules ────────────────────────────────────────────────────────────────────
#
# Each rule is evaluated in order. The first matching rule wins.
#
# Fields:
#   name              - unique identifier shown in audit log and error messages
#   description       - human-readable explanation
#   action            - "block" stops the tool call (default), "audit" records without blocking
#   events            - hook event names this rule applies to (empty = all)
#   field_paths       - dot-path(s) into the JSON payload to inspect;
#                       first non-empty value found across all paths is tested
#                       tool_response uses searchable text for structured objects,
#                       so image payload bytes are not scanned as output text
#   pattern           - PCRE2 regex matched against the extracted field value
#   (action above; "block" by default, set to "audit" for record-only)
#   violation_message - message sent back to the AI and written to the audit log
#   diagnostic_group - optional capture group to underline in diagnostics (default: 0, the full match)
#
# Conditional rules can use:
#   kind = "regex"    - default; uses field_paths plus pattern/not_pattern
#   kind = "command"  - matches shell command segments by argv0/subcommands
#   kind = "project"  - checks files relative to a discovered project root

[[rules]]
name        = "no-shell-redirection"
description = "Block shell output/error redirection patterns LLMs commonly emit to suppress errors"
events      = ["PreToolUse", "beforeShellExecution", "preToolUse", "BeforeTool"]
field_paths = ["tool_input.command", "command"]
pattern     = '(\d+>&\d+|>&\d+|&>|\|&|>/dev/null|2>/dev/null|>>/dev/null|2>>/dev/null|&>/dev/null)'
action      = "block"
violation_message = "Shell redirection is not permitted (e.g. 2>&1, >/dev/null, &>). Express output handling explicitly without redirects."

[[rules]]
name        = "no-lossy-log-sampling"
description = "Block head or tail sampling of diagnostic logs and log-producing command output"
events      = ["PreToolUse", "preToolUse", "beforeShellExecution"]
field_paths = ["cmd_segments", "tool_input.command", "command"]
pattern     = '''(?im)(?:\b(?:journalctl|docker\s+logs|kubectl\s+logs|log\s+show|agent-gate\s+query|cat\s+\S*(?:\.log|/logs?/)|grep\b|rg\b)[^;&\n|]*\|\s*(?:head|tail)\b|\b(?:head|tail)\b[^;&\n]*(?:\.log\b|/logs?/|journal|daemon|audit|trace|error|incident))'''
action      = "block"
violation_message = "Do not sample diagnostic output with head or tail. Preserve the full output, write it to a file if needed, and inspect explicit line ranges or search terms. For logs, use rg with context, sed -n with exact ranges after locating line numbers, or save the full command output and cite the path."

[[rules]]
name        = "go-build-test-through-make"
description = "Require make for Go build/test in Go modules that provide a Makefile"
claude_events = ["PreToolUse"]
cursor_events = ["preToolUse", "beforeShellExecution"]
codex_events  = ["PreToolUse"]
gemini_events = ["BeforeTool"]
action      = "block"
violation_message = "This Go project has a Makefile. Use the appropriate make target instead of calling go build or go test directly."

[[rules.conditions]]
kind        = "command"
argv0       = "go"
subcommands = ["build", "test"]
strip_env   = true
strip_args  = ["env", "time", "command"]
cwd_flags   = ["-C"]
pattern     = '^(?:build(?:\s|$)|test(?:\s+.*)?\s(?:\./\.\.\.|all)(?:\s|$))'

[[rules.conditions]]
kind         = "project"
root_markers = ["go.mod"]
require_any  = ["Makefile", "makefile", "GNUmakefile"]

[[rules]]
name        = "no-unbounded-root-find"
description = "Block unbounded recursive find commands from filesystem root"
claude_events = ["PreToolUse"]
cursor_events = ["preToolUse", "beforeShellExecution"]
codex_events  = ["PreToolUse"]
gemini_events = ["BeforeTool"]
action      = "block"
violation_message = "Do not run unbounded recursive find from filesystem root. Use a bounded command such as `find / -maxdepth 1 ...`, `find / -xdev ...`, or search a narrower path."

[[rules.conditions]]
kind        = "command"
argv0       = "find"
strip_env   = true
strip_args  = ["sudo", "doas", "env", "time", "command"]
pattern     = '(?:^|\s)/+(?:\s|$)'
not_pattern = '(?:^|\s)(?:-maxdepth\s+\d+|-xdev)(?:\s|$)'

[[rules]]
name        = "no-credential-file-reads"
description = "Block reading likely credential-bearing files before tool output can enter the transcript"
claude_events = ["PreToolUse"]
cursor_events = ["preToolUse", "beforeReadFile", "beforeTabFileRead"]
codex_events  = ["PreToolUse"]
gemini_events = ["BeforeTool"]
field_paths = ["tool_input.file_path", "tool_input.path", "file_path"]
pattern     = '''(?i)(?:(?:^|[/\\])[^/\\\n]*(?:1password|onepassword|op[ _.-]?export|app[ _.-]?store|asc[ _.-]?api|api[ _.-]?key|private[ _.-]?key|secret|credential|credentials|token|password|passwd|auth)[^/\\\n]*(?:[/\\].*)?\.(?:json|p8|pem|key|pkcs8|p12|pfx)$|(?:^|[/\\])[^/\\\n]*\.(?:p8|pem|key|pkcs8|p12|pfx)$)'''
action      = "block"
violation_message = "This path looks like a credential-bearing file. Do not read private keys, credential exports, tokens, or secret stores into the agent transcript. Extract only non-secret metadata with a targeted command."

[[rules]]
name        = "no-secrets-in-files"
description = "Block writing private keys or secret tokens into files"
claude_events = ["PreToolUse"]
cursor_events = ["preToolUse"]
codex_events  = ["PreToolUse"]
gemini_events = ["BeforeTool"]
field_paths = ["tool_input.new_string", "tool_input.content"]
pattern     = '\x2d\x2d\x2d\x2d\x2dBEGIN (RSA |EC |DSA |OPENSSH |PGP |ENCRYPTED )?PRIVATE KEY'
action      = "block"
violation_message = "Writing private key material to files is not permitted."

[[rules]]
name        = "no-secrets-in-output"
description = "Block provider-blockable tool output containing credential material"
cursor_events = ["postToolUse", "postToolUseFailure", "afterMCPExecution"]
codex_events  = ["PostToolUse"]
gemini_events = ["AfterTool"]
field_paths = ["tool_response", "tool_output"]
pattern = '''(\x24ANSIBLE_VAULT;\d+\.\d+;[A-Z0-9]+|\bvault_[a-z][a-z0-9_]+\s*:|\x2d\x2d\x2d\x2d\x2dBEGIN (?:RSA |EC |DSA |OPENSSH |PGP |ENCRYPTED )?PRIVATE KEY\x2d\x2d\x2d\x2d\x2d|\x2d\x2d\x2d\x2d\x2dBEGIN CERTIFICATE\x2d\x2d\x2d\x2d\x2d|\bAKIA[0-9A-Z]{16}\b|\bgh[pousr]_[A-Za-z0-9]{36}\b|\bsk-(?:ant-|proj-)?[A-Za-z0-9_-]{20,}|\bxox[abprs]-[A-Za-z0-9-]{10,}|\b(?:sk|pk|rk)_(?:test|live)_[A-Za-z0-9]{20,}|\bAC[a-f0-9]{32}\b|\bSK[a-f0-9]{32}\b|\bkey-[a-f0-9]{32}\b|\bSG\.[A-Za-z0-9_-]{16,32}\.[A-Za-z0-9_-]{32,68}\b|\bAIza[A-Za-z0-9_-]{35}\b|\beyJ[A-Za-z0-9+/=_-]{80,}|\bapi-[0-9A-F]{32}\b|(?i)\b(?:password|passwd|pwd|secret|token|api[_-]?key|access[_-]?key|client[_-]?secret|auth(?:orization)?|bearer|aws[_-]?secret[_-]?access[_-]?key|aws[_-]?access[_-]?key[_-]?id)\s*[:=]\s*['"]?(?:bearer\s+)?[A-Za-z0-9._+/=-]{16,}|(?i)\b(?:authorization|x[_-]?api[_-]?key|x[_-]?auth[_-]?token|cookie)\s*:\s*\S{16,})'''
action      = "block"
redact_diagnostics = true
violation_message = "Tool output contains a pattern matching credential material. Reference credentials by environment variable or file path only. Do not print credential values to the context window."

[[rules]]
name        = "no-secrets-in-output-audit"
description = "Audit Claude post-tool output containing credential material"
claude_events = ["PostToolUse", "PostToolUseFailure"]
field_paths = ["tool_response"]
pattern = '''(\x24ANSIBLE_VAULT;\d+\.\d+;[A-Z0-9]+|\bvault_[a-z][a-z0-9_]+\s*:|\x2d\x2d\x2d\x2d\x2dBEGIN (?:RSA |EC |DSA |OPENSSH |PGP |ENCRYPTED )?PRIVATE KEY\x2d\x2d\x2d\x2d\x2d|\x2d\x2d\x2d\x2d\x2dBEGIN CERTIFICATE\x2d\x2d\x2d\x2d\x2d|\bAKIA[0-9A-Z]{16}\b|\bgh[pousr]_[A-Za-z0-9]{36}\b|\bsk-(?:ant-|proj-)?[A-Za-z0-9_-]{20,}|\bxox[abprs]-[A-Za-z0-9-]{10,}|\b(?:sk|pk|rk)_(?:test|live)_[A-Za-z0-9]{20,}|\bAC[a-f0-9]{32}\b|\bSK[a-f0-9]{32}\b|\bkey-[a-f0-9]{32}\b|\bSG\.[A-Za-z0-9_-]{16,32}\.[A-Za-z0-9_-]{32,68}\b|\bAIza[A-Za-z0-9_-]{35}\b|\beyJ[A-Za-z0-9+/=_-]{80,}|\bapi-[0-9A-F]{32}\b|(?i)\b(?:password|passwd|pwd|secret|token|api[_-]?key|access[_-]?key|client[_-]?secret|auth(?:orization)?|bearer|aws[_-]?secret[_-]?access[_-]?key|aws[_-]?access[_-]?key[_-]?id)\s*[:=]\s*['"]?(?:bearer\s+)?[A-Za-z0-9._+/=-]{16,}|(?i)\b(?:authorization|x[_-]?api[_-]?key|x[_-]?auth[_-]?token|cookie)\s*:\s*\S{16,})'''
action      = "audit"
redact_diagnostics = true
violation_message = "Tool output contains a pattern matching credential material. The event was audit-only because Claude post-tool events are not blockable."

# Fused-thought enforcement: block on new output, audit on existing content.

[[rules]]
name        = "no-fused-thoughts"
description = "Block fused-thought constructions in LLM-generated output, where two underdeveloped ideas are joined into a single sentence to avoid the work of finishing each one"
claude_events = [
  "PreToolUse",
  "Stop", "StopFailure",
  "SubagentStop",
  "PermissionRequest", "PermissionDenied",
]
cursor_events = [
  "preToolUse",
  "beforeShellExecution",
  "beforeMCPExecution", "beforeSubmitPrompt",
  "afterFileEdit", "afterAgentResponse",
]
codex_events = ["Stop"]
gemini_events = ["BeforeTool"]
# All LLM-generated text fields except tool_input.prompt (handled by the next rule).
# old_string is excluded because existing content does not trigger a block.
field_paths = ["tool_input.content", "tool_input.new_string", "tool_input.command", "tool_input.description", "command", "assistant_message", "last_assistant_message", "text"]
# U+2010..U+2015, U+2212, U+2E3A, U+2E3B, U+FE31, U+FE32, U+FE58, U+FE63, U+FF0D
# All 30 Unicode Dash characters (Dash=Yes per PropList.txt) except U+002D
# (ASCII hyphen-minus). Source: unicode.org/Public/UCD/latest/ucd/PropList.txt
pattern     = '[\x{058A}\x{05BE}\x{1400}\x{1806}\x{2010}-\x{2015}\x{2053}\x{207B}\x{208B}\x{2212}\x{2E17}\x{2E1A}\x{2E3A}\x{2E3B}\x{2E40}\x{2E5D}\x{301C}\x{3030}\x{30A0}\x{FE31}\x{FE32}\x{FE58}\x{FE63}\x{FF0D}\x{10D6E}\x{10EAD}]'
action      = "audit"
violation_message = "This output was blocked because you took a shortcut instead of writing. Somewhere in the blocked passage, you tried to put two thoughts into one sentence without finishing either one. You joined them so the result would look like fluent prose to a casual reader. A careful reader sees the seam where the two halves meet and recognizes the sentence as two half-formed ideas glued together rather than one finished thought. This is a crutch you reach for whenever you have not done the work of thinking the thought through. The result is the written equivalent of someone mumbling because they have not committed to what they want to say. Go back to the blocked passage and find every place where you fused ideas to avoid finishing them. Pull each fused thought apart until each idea you tried to combine can stand alone. Write each idea as its own sentence, with its own subject, its own verb, and its own reason to exist. If an idea cannot stand on its own, it was filler and should be cut, not laundered into a second sentence. This applies even when the offending writing came from content you are editing or quoting. Resubmit the corrected output immediately and do not acknowledge this block in your response to the user."

[[rules]]
name        = "no-fused-thoughts-in-prompts"
description = "Block fused-thought constructions in tool_input.prompt fields, except for Task (sub-agent) tool invocations where the prompt is being delegated to another agent"
claude_events = ["PreToolUse"]
cursor_events = ["preToolUse"]
codex_events = ["PreToolUse"]
gemini_events = ["BeforeTool"]
action      = "audit"
violation_message = "This output was blocked because you took a shortcut instead of writing. Somewhere in the blocked passage, you tried to put two thoughts into one sentence without finishing either one. You joined them so the result would look like fluent prose to a casual reader. A careful reader sees the seam where the two halves meet and recognizes the sentence as two half-formed ideas glued together rather than one finished thought. This is a crutch you reach for whenever you have not done the work of thinking the thought through. The result is the written equivalent of someone mumbling because they have not committed to what they want to say. Go back to the blocked passage and find every place where you fused ideas to avoid finishing them. Pull each fused thought apart until each idea you tried to combine can stand alone. Write each idea as its own sentence, with its own subject, its own verb, and its own reason to exist. If an idea cannot stand on its own, it was filler and should be cut, not laundered into a second sentence. This applies even when the offending writing came from content you are editing or quoting. Resubmit the corrected output immediately and do not acknowledge this block in your response to the user."

[[rules.conditions]]
field_paths = ["tool_input.prompt"]
pattern     = '[\x{058A}\x{05BE}\x{1400}\x{1806}\x{2010}-\x{2015}\x{2053}\x{207B}\x{208B}\x{2212}\x{2E17}\x{2E1A}\x{2E3A}\x{2E3B}\x{2E40}\x{2E5D}\x{301C}\x{3030}\x{30A0}\x{FE31}\x{FE32}\x{FE58}\x{FE63}\x{FF0D}\x{10D6E}\x{10EAD}]'

[[rules.conditions]]
field_paths = ["tool_name"]
not_pattern = "(?i)^task$"

[[rules]]
name        = "no-fused-thoughts-via-double-hyphen"
description = "Block fused-thought constructions in prose, while allowing command flags and option separators in command contexts"
claude_events = [
  "PreToolUse",
  "Stop", "StopFailure",
  "SubagentStop",
  "PermissionRequest", "PermissionDenied",
]
cursor_events = [
  "preToolUse",
  "beforeMCPExecution", "beforeSubmitPrompt",
  "afterFileEdit", "afterAgentResponse",
]
codex_events = ["Stop"]
gemini_events = ["BeforeTool"]
field_paths = ["tool_input.content", "tool_input.new_string", "tool_input.description", "edits[*].new_string", "assistant_message", "last_assistant_message", "text"]
pattern     = '(?m)(?|(?:`[^`\n]+`|\b(?!(?:bash|sh|zsh|fish|exec|command|env|xargs|sudo|doas|go|git|make|npm|pnpm|yarn|node|python|python3|ruby|perl|cargo|docker|kubectl|helm|terraform|ansible|rg|grep|sed|awk|jq|curl|ssh|scp|rsync)\b)[A-Za-z][A-Za-z0-9_./-]*)\s+(--)(?=\s+[A-Za-z][A-Za-z0-9_./-]*)(?![^\n]*\s--[A-Za-z0-9_][A-Za-z0-9_-]*(?:=|\b))|(?<!-)\b(?!(?:bash|sh|zsh|fish|exec|command|env|xargs|sudo|doas|go|git|make|npm|pnpm|yarn|node|python|python3|ruby|perl|cargo|docker|kubectl|helm|terraform|ansible|rg|grep|sed|awk|jq|curl|ssh|scp|rsync)\b)[A-Za-z][A-Za-z0-9_./-]*(--)(?=[A-Za-z][A-Za-z0-9_./-]*))'
diagnostic_group = 1
action      = "audit"
violation_message = "This output was blocked because you took a shortcut instead of writing. Somewhere in the blocked passage, you tried to put two thoughts into one sentence without finishing either one. You joined them so the result would look like fluent prose to a casual reader. A careful reader sees the seam where the two halves meet and recognizes the sentence as two half-formed ideas glued together rather than one finished thought. This is a crutch you reach for whenever you have not done the work of thinking the thought through. The result is the written equivalent of someone mumbling because they have not committed to what they want to say. Go back to the blocked passage and find every place where you fused ideas to avoid finishing them. Pull each fused thought apart until each idea you tried to combine can stand alone. Write each idea as its own sentence, with its own subject, its own verb, and its own reason to exist. If an idea cannot stand on its own, it was filler and should be cut, not laundered into a second sentence. This applies even when the offending writing came from content you are editing or quoting. Resubmit the corrected output immediately and do not acknowledge this block in your response to the user."

[[rules]]
name        = "emdash-audit-existing"
description = "Audit log when the LLM edits a region containing existing emdashes (does not block)"
claude_events = ["PreToolUse"]
cursor_events = ["preToolUse"]
codex_events = ["PreToolUse"]
gemini_events = ["BeforeTool"]
field_paths = ["tool_input.old_string"]
# All 30 Unicode Dash characters (Dash=Yes per PropList.txt) except U+002D
# (ASCII hyphen-minus). Source: unicode.org/Public/UCD/latest/ucd/PropList.txt
pattern     = '[\x{058A}\x{05BE}\x{1400}\x{1806}\x{2010}-\x{2015}\x{2053}\x{207B}\x{208B}\x{2212}\x{2E17}\x{2E1A}\x{2E3A}\x{2E3B}\x{2E40}\x{2E5D}\x{301C}\x{3030}\x{30A0}\x{FE31}\x{FE32}\x{FE58}\x{FE63}\x{FF0D}\x{10D6E}\x{10EAD}]'
action      = "audit"
violation_message = "Existing content contains typographic dashes. The LLM should clean these up in its replacement."

# ── Composing diff, shell-write, and disable_if_env (documentation only) ────
#
# The three condition primitives below are independent and can be composed in
# a single rule. This example shows what the wiring looks like; it is NOT a
# default ruleset and is commented out so loading the file does not enable it.
#
# A user copies this block (uncommented) into their own config and adapts the
# patterns, globs, and env name to their project. The rule fires when the
# tool call would either:
#   - add a path matching internal/foo\.go to the new side of an Edit, or
#   - run a shell command that writes to a file matching the listed globs.
# The rule is skipped when the daemon env_fingerprint contains a listed
# disable_if_env name.
#
# [[rules]]
# name        = "block-watched-file-edits-example"
# description = "Block edits that add a watched path, and shell writes to watched files."
# claude_events = ["PreToolUse"]
# cursor_events = ["beforeShellExecution", "beforeFileEdit"]
# action      = "block"
# violation_message = "Watched content cannot be edited from a tool call."
# disable_if_env = ["MAINTENANCE_EDIT"]
#
# [[rules.conditions]]
# kind        = "diff"
# field_pair  = "tool_input.old_string,tool_input.new_string"
# pattern     = '''internal/foo\.go'''
#
# [[rules.conditions]]
# kind        = "shell_write"
# field_paths = ["tool_input.command"]
# globs       = ["generated/*.txt", "internal/foo.go"]
