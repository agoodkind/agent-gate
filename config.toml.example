# agent-gate annotated configuration
#
# Copy this file to:
#   ${XDG_CONFIG_HOME:-$HOME/.config}/agent-gate/config.toml
#
# The complete file is valid production TOML. Only the deterministic example
# rule is enabled. Optional examples stay commented so copying this file does
# not start external validators or inference calls.

[log]
level = "info" # debug | info | warn | error

[audit]
enabled = true
level = "info"

[audit.outputs.sqlite]
# Empty selects ${XDG_STATE_HOME:-$HOME/.local/state}/agent-gate/sqlite/audit.db.
# The database owns durable intake, derived decisions, and evaluator records.
path = ""

[paths]
# Legacy compatibility path for older per-conversation logs. Current audit
# state does not use this directory.
conversations_dir = ""

[update]
enabled = true
mode = "check" # check | apply
interval = "24h"
repo = "agoodkind/agent-gate"
allow_prerelease = false

[telemetry]
otlp_endpoint = ""
slow_op_threshold_ms = 0

[performance.hook]
# Zero selects the runtime default for every field.
hot_concurrency = 0
hot_queue_wait_ms = 0
inference_phase_timeout_ms = 0
deferred_queue_limit = 0
deferred_workers = 0

[performance.hook.cache]
# This cache is daemon memory shared by exec validators, infer conditions, and
# `agent-gate kv`. It is cleared on daemon restart and reconfigured on reload.
max_entries = 4096
max_value_bytes = 1048576
prune_interval_ms = 30000

# Named inference points declare a reusable endpoint and model. A point does
# nothing until a [[rules.eval]] entry references it with `use`.
[inference.local_review]
endpoint = "127.0.0.1:5401"
model = "agent-gate-review"
reasoning_effort = "low"
confidence_source = "output_field" # output_field | logprob; omit for no confidence source
confidence_field = "confidence"
confidence_threshold = 0.80
timeout_ms = 1500 # zero uses the 4000 ms point default

# Every applicable rule is evaluated. More than one rule can match one event,
# and the blocking response reports every concrete match. A simple rule tests
# the first non-empty selected field. `not_pattern`, when set, exempts matching
# values.
[[rules]]
name = "build-through-make"
description = "Require the repository build target"
events = ["PreToolUse", "preToolUse", "beforeShellExecution", "BeforeTool"]
field_paths = ["tool_input.command", "command"]
pattern = '''(?:^|\s)go\s+build(?:\s|$)'''
not_pattern = '''(?:^|\s)go\s+build\s+-n(?:\s|$)'''
action = "block" # block | audit; block is the default
violation_message = "Run the repository build target instead of go build directly."
diagnostic_group = 0
diagnostic_format = "detailed" # detailed | message_only
redact_diagnostics = false
disable_if_env = ["AGENT_GATE_MAINTENANCE"]

# Provider-specific filters can supplement or replace shared `events` for the
# four providers with dedicated fields:
#   claude_events = ["PreToolUse"]
#   codex_events = ["PreToolUse"]
#   cursor_events = ["preToolUse", "beforeShellExecution"]
#   gemini_events = ["BeforeTool"]
# Copilot uses shared `events` because it carries Claude-style event names
# through the Copilot adapter.

# A conditional rule uses all-match semantics. Every [[rules.conditions]]
# entry must match before the rule fires. Conditions run in order, so cheap
# deterministic filters should precede filesystem, process, or inference work.
#
# Supported kinds and their fields:
#
# regex
#   field_paths, pattern, not_pattern, diagnostic_group
# command
#   argv0, subcommands, strip_env, strip_args, cwd_flags, pattern, not_pattern
# project
#   root_markers, require_any, require_all, forbid_any
# diff
#   field_pair, pattern, not_pattern
# shell_read_secret
#   field_paths, pattern, path_pattern, max_bytes, remote_policy, read_specs
# shell_write
#   field_paths, globs, write_specs
# exec
#   command, timeout_ms, cache_key, cache_ttl_ms, block_on, on_error,
#   search_tools, for_each, match_mode, stdout_json_field, stdout_json_equals
# infer
#   endpoint, layer_name, prompt or prompt_file, input_field, output_schema or
#   output_schema_file, model, generation options, response predicate, timeout,
#   cache, error policy, and optional recent-turn context fields
# git_default_branch, git_primary_checkout, git_ref_move
#   typed Git state gates; git_ref_move does not accept field_paths

# Example all-match rule:
#
# [[rules]]
# name = "go-build-in-make-project"
# description = "Require make for Go modules that provide a Makefile"
# events = ["PreToolUse", "preToolUse", "beforeShellExecution", "BeforeTool"]
# action = "block"
# violation_message = "Run make build."
#
# [[rules.conditions]]
# kind = "command"
# argv0 = "go"
# subcommands = ["build"]
# strip_env = true
# strip_args = ["env", "time", "command"]
# cwd_flags = ["-C"]
#
# [[rules.conditions]]
# kind = "project"
# root_markers = ["go.mod"]
# require_any = ["Makefile", "makefile", "GNUmakefile"]

# External validator reference:
#
# [[rules]]
# name = "approved-code-search"
# description = "Require an approved target for code search"
# events = ["PreToolUse", "preToolUse", "beforeShellExecution", "BeforeTool"]
# action = "block"
# violation_message = "Use the approved search path."
#
# [[rules.conditions]]
# kind = "regex"
# field_paths = ["tool_input.command", "command"]
# pattern = '''\b(?:grep|rg)\b'''
#
# [[rules.conditions]]
# kind = "exec"
# command = ["/absolute/path/to/validator", "{{item}}"]
# search_tools = ["grep", "rg"]
# for_each = "cmd_read_targets"
# match_mode = "any" # any | all
# cache_key = "cmd_read_targets"
# cache_ttl_ms = 60000
# timeout_ms = 1500 # default 1500, maximum 4000
# stdout_json_field = "approved"
# stdout_json_equals = false
# block_on = "match" # nonzero | zero | match
# on_error = "open" # open allows on timeout/error; closed blocks
#
# `timeout_ms` is the synchronous hook budget. A validator that outlives this
# budget applies `on_error` to the current event, then continues for at most 30
# seconds in the background. A successful background result enters the
# process-local cache, so the next matching event can use it. Parallel misses
# for one cache key share the in-flight run. Errors are not cached.
#
# `cmd_read_targets` drops remote and unresolved local read paths instead of
# inventing a target. `exec_targets` falls back from resolved read targets to a
# file path, then to a resolved effective directory, then to the base directory.
# An unresolved effective directory reaches an external validator as an empty
# `AGENT_GATE_CWD`; NUL marker bytes never enter its environment or SQLite.
#
# `cmd_write_targets` contains only resolved write paths. A `shell_write`
# condition is stricter: an opaque command or unresolved destination produces
# an unparsed sentinel that matches regardless of globs, so the condition can
# default-deny unknown local write shapes. Remote shell writes are not treated
# as local file writes.

# Evaluator matrix reference:
#
# [[rules]]
# name = "review-primary-checkout-write"
# description = "Review writes to a protected checkout"
# events = ["PreToolUse", "preToolUse", "BeforeTool"]
# intent = "Do not write into the protected primary checkout."
# action = "block"
# violation_message = "Use an isolated worktree."
#
# [[rules.conditions]]
# kind = "git_primary_checkout"
#
# [[rules.eval]]
# kind = "deterministic"
# role = "enforce"
# combine = "union"
#
# [[rules.eval]]
# kind = "infer"
# role = "verify"
# use = "local_review"
# fanout = "individual"
# on_error = "open"
#
# `role = "enforce"` contributes to the final verdict. `role = "verify"` runs
# and records a layer without changing the verdict. Enforcing entries combine
# with `union` by default, which blocks when any enforcer blocks. `and` blocks
# only when every enforcer blocks. Infer entries run concurrently. Their
# `on_error` value decides the entry verdict after endpoint, timeout, status, or
# response errors. A rule with an infer evaluator must declare `intent`.
#
# The judge sees a rule only when the rule's deterministic conditions match the
# command. A rule with no conditions is judged on every command. A rule with a
# condition joins only when the condition matches. The `description` is sent to
# the judge under the rule's id, after the intent, so state the scope and the
# allowances there, not only the prohibition.
#
# Judge rule scoped by a condition, with a full description:
#
# [[rules]]
# name = "judge-source-scan"
# claude_events = ["PreToolUse"]
# action = "audit"
# intent = "Block a bulk read or content search across many repository source files."
# description = "Covers reading or searching the repository's program source in bulk, by grep -r, awk, sed, or cat over several source files, find -exec, or an interpreter that walks and reads many source files. Allows reading a single file, filtering command output through a pipe, a build, or a git operation. Blocked example: grep -r password internal/. Allowed example: cat internal/rules/engine.go."
#
# [[rules.conditions]]
# kind = "regex"
# field_paths = ["tool_input.command"]
# pattern = '\b(grep|rg|awk|sed|find|cat|python3?)\b'
#
# [[rules.eval]]
# kind = "infer"
# role = "enforce"
# use = "mini"
# fanout = "batch"
#
# To scope a judge rule on an external liveness probe, give it an `exec`
# condition. The rule joins the judge only while the probe reports up, and drops
# out when the probe reports down or errors:
#
# [[rules.conditions]]
# kind = "exec"
# command = ["lm-semantic-search", "--json", "codebase", "status", "{{item}}"]
# for_each = "cmd_read_targets"
# search_tools = ["grep", "rg", "cat", "python3"]
# stdout_json_field = "searchable"
# stdout_json_equals = true
# block_on = "match"
# on_error = "open"
# cache_ttl_ms = 2000

# Inline `kind = "infer"` conditions remain supported for structured custom
# schemas. They accept endpoint, layer_name, exactly one prompt declaration,
# exactly one output_schema declaration, model and generation options,
# input_field, cache_key, cache_ttl_ms, timeout_ms (default 1500, maximum 8000),
# block_on (`match` or `nonmatch`), on_error, response_json_field, and
# response_json_equals. Optional recent-turn context uses:
#   context_source = "clyde_recent_turns"
#   context_endpoint
#   context_workspace_field
#   context_session_field
#   context_turn_budget
#   context_max_chars_per_turn
#   context_on_error = "empty" | "error"
